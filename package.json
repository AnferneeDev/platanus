  "description": "MCP server that gives AI agents the ability to discover local businesses and negotiate with them via WhatsApp",
  "type": "module",
  "bin": {
    "agentic-procurement": "./dist/index.js",
    "agentic-procurement-sidecar": "./dist/whatsapp/sidecar.js"
  },
  "scripts": {
    "build": "tsc",
