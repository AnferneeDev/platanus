{
  "name": "agentic-procurement",
  "version": "1.0.0",
  "description": "MCP server that gives AI agents the ability to discover local businesses and negotiate with them via WhatsApp",
  "type": "module",
  "bin": {
    "agentic-procurement": "./dist/mcp/index.js",
    "agentic-procurement-sidecar": "./dist/mcp/whatsapp/sidecar.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/mcp/index.ts",
    "dev:server": "tsx src/server.ts",
    "sidecar": "tsx src/mcp/whatsapp/sidecar.ts",
    "start": "node dist/mcp/index.js",
    "start:server": "node dist/server.js",
    "start:sidecar": "node dist/mcp/whatsapp/sidecar.js"
  },
  "keywords": [
    "mcp",
    "whatsapp",
    "procurement",
    "ai-agent",
    "google-places"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.7.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
